# ============================================================
# WholesaleX Pro — Backend Environment Variables (TEMPLATE)
# ============================================================
# 1. Copy this file to '.env' (cp .env.example .env)
# 2. Fill in your real values below.
# 3. NEVER commit the real '.env' file to GitHub.
# ============================================================

# -----------------------------------------------------------
# 1. Database (PostgreSQL)
# -----------------------------------------------------------
# Ensure PostgreSQL is running locally on port 5432.
# The database 'wholesalex' must exist (create via: CREATE DATABASE wholesalex;)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/wholesalex?schema=public"

# -----------------------------------------------------------
# 2. JWT Authentication
# -----------------------------------------------------------
# Change JWT_SECRET to a strong random string before deploying to production.
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="7d"

# -----------------------------------------------------------
# 3. Google OAuth 2.0 — Step-by-Step Setup
# -----------------------------------------------------------
# 1. Go to https://console.cloud.google.com/ and sign in.
# 2. Create a new project (top-left dropdown) → e.g., "WholesaleX Pro".
# 3. Navigate to "APIs & Services → Library".
# 4. Search "People API" and click ENABLE.
# 5. Go to "APIs & Services → Credentials".
# 6. Click "Create Credentials → OAuth client ID".
# 7. Select "Web application" as the application type.
# 8. Under "Authorized redirect URIs", add EXACTLY:
#    http://localhost:3000/api/v1/auth/google/callback
# 9. Click Create. You will get a Client ID and Client Secret.
# 10. Paste them below (replace the placeholder values).
#
# NOTE: For production, add your live domain redirect URI in the same
# Google Cloud Console client, e.g.:
# https://yourdomain.com/api/v1/auth/google/callback
# -----------------------------------------------------------
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# -----------------------------------------------------------
# 4. App Settings
# -----------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------
# 5. CCAvenue Online Payment Gateway
# -----------------------------------------------------------
# 1. Sign up at https://www.ccavenue.com/ and get a merchant account.
# 2. In your CCAvenue dashboard, go to "Settings → API Keys".
# 3. Copy the Merchant ID, Access Code, and Working Key.
# 4. Paste them below.
#
# TEST MODE: Use the test credentials provided by CCAvenue.
#   Gateway URL: https://test.ccavenue.com/transaction/transaction.do?command=initiateTransaction
# PRODUCTION: Use live credentials.
#   Gateway URL: https://secure.ccavenue.com/transaction/transaction.do?command=initiateTransaction
# -----------------------------------------------------------
CCAVENUE_MERCHANT_ID="your-merchant-id"
CCAVENUE_ACCESS_CODE="your-access-code"
CCAVENUE_WORKING_KEY="your-working-key"
CCAVENUE_GATEWAY_URL="https://test.ccavenue.com/transaction/transaction.do?command=initiateTransaction"

# -----------------------------------------------------------
# 6. SMTP Email Configuration (for notifications)
# -----------------------------------------------------------
# Used for sending OTP emails, order confirmations, and notifications.
# You can use any SMTP provider: Gmail, SendGrid, AWS SES, Mailgun, etc.
#
# Example (Gmail):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASS=your-app-password
#   SMTP_FROM=WholesaleX Pro <your-email@gmail.com>
#
# If left empty, emails will be skipped and only in-app notifications work.
# -----------------------------------------------------------
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="WholesaleX Pro <noreply@wholesalex.com>"

# -----------------------------------------------------------
# 7. Frontend URLs (used for CORS + OAuth redirects)
# -----------------------------------------------------------
# FRONTEND_URL must match where your Next.js app runs.
# ADMIN_URL is reserved for a future admin panel.
FRONTEND_URL="http://localhost:3001"
ADMIN_URL="http://localhost:3002"
